# =============================================================================
# e3-assessment — environment variables
# Copy this to .env and fill in your keys.
# Only DAILY_API_KEY + at least one LLM key are required to run the demo.
# =============================================================================

# ── Transport ─────────────────────────────────────────────────────────────────
# Get a free key at https://dashboard.daily.co/
DAILY_API_KEY=

# ── STT ───────────────────────────────────────────────────────────────────────
# Get a free key at https://console.deepgram.com/
DEEPGRAM_API_KEY=

# ── LLM (priority order: Groq → OpenRouter → Gemini) ─────────────────────────
# https://console.groq.com/keys
GROQ_API_KEY=

# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ── Optional tuning ───────────────────────────────────────────────────────────
# HuggingFace token (needed if Qwen3-TTS is gated)
HF_TOKEN=

# Override which Daily room URL the bot joins (created automatically if blank)
DAILY_ROOM_URL=

# Audio sample rate sent to Pipecat transport (Hz). 24000 matches Qwen3-TTS output.
AUDIO_SAMPLE_RATE=24000

# Max codec tokens the TTS talker will generate per utterance
TTS_MAX_TOKENS=1500

# Megakernel: number of decode blocks (default tuned for RTX 5090)
LDG_NUM_BLOCKS=128
LDG_BLOCK_SIZE=512
